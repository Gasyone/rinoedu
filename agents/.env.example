# ======================================================
# RINOEDU AI FACTORY — Environment Variables
# ======================================================
# HƯỚNG DẪN:
# 1. Copy file này thành .env (cùng thư mục)
# 2. Điền API Key của bạn vào
# 3. KHÔNG BAO GIỜ commit file .env lên Git!
# ======================================================

# --- CHỌN MODEL LLM ---
# Dùng Gemini:
GEMINI_API_KEY=your_gemini_api_key_here

# Dùng OpenAI (comment dòng trên và mở dòng này nếu dùng OpenAI):
# OPENAI_API_KEY=your_openai_api_key_here

# Model được dùng (mặc định Gemini Flash)
# Gemini:  gemini/gemini-2.0-flash
# OpenAI:  gpt-4o
LLM_MODEL=gemini/gemini-2.0-flash

# --- ĐƯỜNG DẪN DỰ ÁN ---
# Trỏ đến thư mục gốc của Rinoapp (thư mục cha của agents/)
RINOAPP_ROOT=c:\Users\Jacky Tran\Documents\Rinoapp
